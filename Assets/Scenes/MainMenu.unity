  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=60><b>Game Guide</b></size>\r\n\tGet all the collectables\r\n\tAvoid
    dying (you lose lives)\r\n\t\tBeginner Level = don't touch water\r\n\tGet to
    the final platform\r\n\tOptional: Complete the level within the time limit\n\tfor
    bonus score (1 point per second remaining)\r\n\r\n<size=60><b>Controls</b></size>\r\n<size=45>Keyboard
    and Mouse</size>\r\n\tUse <sprite=\"KeyboardAndMouseSprites/W_Key_Dark\" name=\"W_Key_Dark\"><sprite=\"KeyboardAndMouseSprites/A_Key_Dark\"
    name=\"A_Key_Dark\"><sprite=\"KeyboardAndMouseSprites/S_Key_Dark\" name=\"S_Key_Dark\"><sprite=\"KeyboardAndMouseSprites/D_Key_Dark\"
    name=\"D_Key_Dark\"> to move and <sprite=\"KeyboardAndMouseSprites/Mouse_Simple_Key_Dark\"
    name=\"Mouse_Simple_Key_Dark\"> to rotate the camera\r\n\tPress and hold <sprite=\"KeyboardAndMouseSprites/Shift_Key_Dark\"
    name=\"Shift_Key_Dark\"> to run\r\n\tPress <sprite=\"KeyboardAndMouseSprites/Space_Key_Dark\"
    name=\"Space_Key_Dark\"> to jump\r\n\tPress <sprite=\"KeyboardAndMouseSprites/C_Key_Dark\"
    name=\"C_Key_Dark\"> to toggle crouch\r\n<size=45>Xbox Controller</size>\r\n\tUse
    <sprite=\"XInputSprites/XboxSeriesX_Left_Stick\" name=\"XboxSeriesX_Left_Stick\">
    to move and <sprite=\"XInputSprites/XboxSeriesX_Right_Stick\" name=\"XboxSeriesX_Right_Stick\">
    to rotate the camera\r\n\tPress and hold <sprite=\"XInputSprites/XboxSeriesX_Left_Stick_Click\"
    name=\"XboxSeriesX_Left_Stick_Click\"> to run\r\n\tPress <sprite=\"XInputSprites/XboxSeriesX_A\"
    name=\"XboxSeriesX_A\"> to jump\r\n\tPress <sprite=\"XInputSprites/XboxSeriesX_B\"
    name=\"XboxSeriesX_B\"> to toggle crouch\r\n<size=45>PlayStation Controller</size>\r\n\tUse
    <sprite=\"DualShockSprites/PS5_Left_Stick\" name=\"PS5_Left_Stick\"> to move
    and <sprite=\"DualShockSprites/PS5_Right_Stick\" name=\"PS5_Right_Stick\"> to
    rotate the camera\r\n\tPress and hold <sprite=\"DualShockSprites/PS5_Left_Stick_Click\"
    name=\"PS5_Left_Stick_Click\"> to run\r\n\tPress <sprite=\"DualShockSprites/PS5_Cross\"
    name=\"PS5_Cross\"> to jump\r\n\tPress <sprite=\"DualShockSprites/PS5_Circle\"
    name=\"PS5_Circle\"> to toggle crouch\r\n<size=45>Nintendo Switch Pro Controller</size>\r\n\tUse
    <sprite=\"SwitchSprites/Switch_Left_Stick\" name=\"Switch_Left_Stick\"> to move
    and <sprite=\"SwitchSprites/Switch_Right_Stick\" name=\"Switch_Right_Stick\">
    to rotate the camera\r\n\tPress and hold <sprite=\"SwitchSprites/Switch_Left_Stick_Click\"
    name=\"Switch_Left_Stick_Click\"> to run\r\n\tPress <sprite=\"SwitchSprites/Switch_B\"
    name=\"Switch_B\"> to jump\r\n\tPress <sprite=\"SwitchSprites/Switch_A\" name=\"Switch_A\">
    to toggle crouch\r\n<size=45>Other Controller</size>\r\n\tUse <sprite=\"GenericControllerSprites/360_Left_Stick\"
    name=\"360_Left_Stick\"> to move and <sprite=\"GenericControllerSprites/360_Right_Stick\"
    name=\"360_Right_Stick\"> to rotate the camera\r\n\tPress and hold <sprite=\"GenericControllerSprites/360_Left_Stick_Click\"
    name=\"360_Left_Stick_Click\"> to run\r\n\tPress <sprite=\"GenericControllerSprites/Positional_Prompts_Down\"
    name=\"Positional_Prompts_Down\"> to jump\r\n\tPress <sprite=\"GenericControllerSprites/Positional_Prompts_Right\"
    name=\"Positional_Prompts_Right\"> to toggle crouch"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
